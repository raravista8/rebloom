# ── Перецвет / rebloom — env template. Copy to .env and fill. NEVER commit .env. ──

# App
APP_ENV=local                      # local | staging | prod
APP_SECRET_KEY=                    # random 32+ bytes, session signing
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Postgres (managed in prod)
DATABASE_URL=postgresql+psycopg://rebloom_app:CHANGE_ME@localhost:5432/rebloom
DATABASE_REPLICA_URL=              # read-replica DSN (optional at launch)
DB_MIGRATOR_URL=postgresql+psycopg://rebloom_migrator:CHANGE_ME@localhost:5432/rebloom

# Redis (queue + sessions + counters + pubsub)
REDIS_URL=redis://localhost:6379/0

# Object Storage (S3-compatible, RF) + CDN
S3_ENDPOINT=
S3_REGION=ru-central1
S3_BUCKET=rebloom-prod-photos
S3_ACCESS_KEY=
S3_SECRET_KEY=
CDN_BASE_URL=

# ЮKassa (escrow «Безопасная сделка» + split + payout). Card data NEVER stored here.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=           # for signature verification
YOOKASSA_WEBHOOK_IP_ALLOWLIST=     # comma-separated provider IPs
PLATFORM_COMMISSION_BPS=1000        # default 1000 = 10% (ADR-0010)
COMMISSION_WHO_PAYS=seller          # seller | buyer | split (ADR-0010)

# Яндекс Доставка (courier, hybrid)
YANDEX_DELIVERY_API_TOKEN=

# SMS provider (OTP login)
SMS_PROVIDER=                      # smsru | mts_exolve | ...
SMS_API_KEY=
SMS_SENDER=

# Telegram bot (egress MUST go via proxy outside RF — OPERATIONS §4)
TG_BOT_TOKEN=
TG_PROXY_URL=                      # e.g. socks5://user:pass@host:port (relay outside RF)
TG_ADMIN_CHAT_ID=                  # best-effort founder alerts

# Email (founder/user alerts; Yandex SMTP implicit TLS on 465)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=                     # Yandex app-password, not login password
SMTP_FROM=
FOUNDER_EMAIL=

# Admin 2FA
ADMIN_2FA_REQUIRED=true            # keep true on prod
ADMIN_IP_ALLOWLIST=                # comma-separated, for /admin

# Notifications / flags
MARKETING_OPT_IN_DEFAULT=false
MAINTENANCE_BANNER=                 # text shown as global banner when set
REFERRAL_ENABLED=false             # feature flag (post-MVP)

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
GLITCHTIP_DSN=

# PII field encryption (ADR-0012) — base64 of 32 random bytes. REQUIRED in prod.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENC_KEY=

# ── Single-box prod deploy (docs/runbooks/deploy-single-box.md) ──
PUBLIC_DOMAIN=peredarim.ru          # Caddy auto-TLS + photo CDN base
POSTGRES_USER=rebloom_app
POSTGRES_MIGRATOR_USER=rebloom_migrator
POSTGRES_PASSWORD=                  # REQUIRED in prod (same pw for app+migrator on single box)
POSTGRES_DB=rebloom
BUILD_VERSION=                      # set on deploy: git rev-parse --short HEAD
BUILD_TIME=                         # set on deploy: date -u +%Y-%m-%dT%H:%M:%SZ
# Off-box encrypted backups (infra/scripts/backup.sh) — money lives on this box.
BACKUP_ENC_KEY=                     # strong passphrase; back up SEPARATELY (lose it = lose backups)
BACKUP_REMOTE=                      # rclone target, e.g. selectel:rebloom-backups (other region)
BACKUP_KEEP_DAYS=14
