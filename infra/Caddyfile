# Caddy edge for the single-box deploy (docs/runbooks/deploy-single-box.md).
# Auto-TLS via Let's Encrypt for {$PUBLIC_DOMAIN}. Routes:
#   /media/*        → uploaded photos on disk (read-only volume)
#   /api/* + health → api (FastAPI; WebSocket proxied transparently)
#   everything else → web (Next.js). Security headers per SECURITY A02.

{$PUBLIC_DOMAIN} {
	encode zstd gzip

	# Uploaded photos (EXIF-stripped WebP) — served straight from disk.
	# /media/photos/<id>/<variant>.webp → /srv/media/photos/<id>/<variant>.webp
	handle /media/* {
		root * /srv
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
		header X-Content-Type-Options "nosniff"
		header Content-Disposition "inline"
	}

	# API surface: /api/* (REST + WebSocket) plus the root-level health/build/OpenAPI
	# routes the backend owns. Caddy proxies WS upgrades transparently.
	@api path /api/* /healthz /readyz /version /openapi.json /docs /redoc
	handle @api {
		reverse_proxy api:8000
	}

	# Everything else → the Next.js web app (pages, assets, _next/*).
	handle {
		reverse_proxy web:3000
	}

	# Security headers (SECURITY A02). HSTS is safe behind auto-HTTPS.
	# CSP is Report-Only first (zero breakage): it logs violations without blocking,
	# so we can confirm the allowlist (Yandex Metrica/Webvisor + Unsplash img proxy +
	# Next inline runtime) before flipping to an enforcing `Content-Security-Policy`.
	# X-Frame-Options enforces clickjacking protection now (CSP frame-ancestors only
	# reports while Report-Only). To enforce CSP later: rename the header to
	# `Content-Security-Policy` and drop 'unsafe-inline' from script-src (nonce/hash).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(self), microphone=()"
		X-Frame-Options "SAMEORIGIN"
		Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://mc.yandex.ru; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://mc.yandex.ru https://*.yandex.ru https://images.unsplash.com; font-src 'self' data:; connect-src 'self' https://mc.yandex.ru https://mc.yandex.com https://*.yandex.ru; frame-src 'self' https://mc.yandex.ru"
		-Server
		-X-Powered-By
	}

	log {
		output stdout
		format json
	}
}
